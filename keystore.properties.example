# Copy this file to keystore.properties and fill in your private release signing values.
# Do NOT commit keystore.properties or the .jks/.keystore file.
# Path can be absolute or relative to the project root.
RELEASE_STORE_FILE=release/countnumber-release.jks
RELEASE_STORE_PASSWORD=change-me
RELEASE_KEY_ALIAS=countnumber
RELEASE_KEY_PASSWORD=change-me

