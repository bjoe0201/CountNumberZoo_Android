# ============================================================
# Android / Gradle build outputs
# ============================================================
/build/
app/build/
**/build/
*.apk
*.aab
*.ap_
*.dex

# Gradle wrapper cache & daemon (keep gradlew scripts, exclude caches)
.gradle/
gradle/wrapper/gradle-wrapper.jar

# ============================================================
# Local machine configuration (never commit these)
# ============================================================
local.properties
*.iml
keystore.properties

# Signing keystores – NEVER upload private keys
*.jks
*.keystore

# ============================================================
# IntelliJ / Android Studio IDE files
# ============================================================
/.idea/caches/
/.idea/libraries/
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
/.idea/deploymentTargetSelector.xml
/.idea/runConfigurations.xml
/.idea/.name
/.idea/markdown.xml
/.idea/CountNumberZoo_Android.iml

# Keep these – useful for consistent project settings across contributors:
# .idea/codeStyles/
# .idea/inspectionProfiles/
# .idea/compiler.xml
# .idea/gradle.xml
# .idea/misc.xml
# .idea/vcs.xml
# .idea/AndroidProjectSystem.xml

# ============================================================
# OS-generated metadata
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ============================================================
# Captures (Android Profiler / Layout Inspector)
# ============================================================
/captures/

# ============================================================
# Native build intermediates
# ============================================================
.externalNativeBuild/
.cxx/

# ============================================================
# Proguard / R8 mapping (generated at build time)
# ============================================================
/app/proguard/

# ============================================================
# Test results & reports
# ============================================================
**/test-results/
**/reports/

# ============================================================
# Lint
# ============================================================
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/

# ============================================================
# Misc
# ============================================================
*.orig
*.class
*.log
*.tmp
*.temp
